PORT=8787

# Branding + event grouping
EVENT_SLUG=alex-and-jordan-2026
HOST_ACCESS_CODE=2004
MAX_UPLOAD_MB=2048

# S3-compatible storage (AWS S3, Cloudflare R2, Backblaze B2 S3 API, etc.)
S3_REGION=auto
S3_BUCKET=your-wedding-bucket
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key

# Optional for non-AWS providers (examples below)
# Cloudflare R2: https://<accountid>.r2.cloudflarestorage.com
# Backblaze B2 S3: https://s3.us-west-004.backblazeb2.com
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=true
